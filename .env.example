# Copiar a .env y completar. .env NUNCA se versiona (ver .gitignore).

# --- Conexión al VPS ---
VPS_HOST=203.0.113.10
VPS_SSH_PORT=22

# --- Usuario creado por scripts/bootstrap.sh ---
DEPLOY_USER=deploy
# Llave pública SSH del usuario deploy (contenido de, por ejemplo, ~/.ssh/id_ed25519.pub)
DEPLOY_SSH_PUBLIC_KEY="ssh-ed25519 AAAA... tu-email@ejemplo.com"
TIMEZONE=America/Bogota

# --- Coolify (para scripts/healthcheck.sh) ---
COOLIFY_URL=https://coolify.cofacture.co

# --- Backups (restic + Cloudflare R2, ver docs/backups.md) ---
RESTIC_REPOSITORY=s3:https://<ACCOUNT_ID>.r2.cloudflarestorage.com/platform-backups
RESTIC_PASSWORD=cambia-esto-por-una-passphrase-larga-y-unica
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_PATHS=/data/coolify
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6

# --- Restauración (scripts/restore.sh) ---
RESTORE_TARGET=/
